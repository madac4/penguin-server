# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=7777
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mongodb://localhost:27017/penguin_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES=7d
JWT_REFRESH_SECRET=change_me_to_another_strong_secret
JWT_REFRESH_EXPIRES=30d

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ─── Mail (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
MAIL_FROM=Penguin <noreply@penguin.dev>

# ─── Client ───────────────────────────────────────────────────────────────────
# Frontend URL used for email confirmation links
CLIENT_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces, or spaces are trimmed)
CORS_ORIGINS=http://localhost:3000,http://localhost:4200
