<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset your password</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #0a0a0a;
      font-family:
        -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    "
  >
    <table
      role="presentation"
      width="100%"
      cellspacing="0"
      cellpadding="0"
      border="0"
      style="background-color: #0a0a0a; min-height: 100vh"
    >
      <tr>
        <td align="center" style="padding: 40px 16px">
          <!-- Decorative top gradient -->
          <table
            role="presentation"
            width="520"
            cellspacing="0"
            cellpadding="0"
            border="0"
            style="max-width: 520px; width: 100%"
          >
            <tr>
              <td
                style="
                  height: 4px;
                  background: linear-gradient(90deg, #b8860b, #daa520, #f5c842, #daa520, #b8860b);
                  border-radius: 4px 4px 0 0;
                "
              ></td>
            </tr>
          </table>

          <!-- Main card -->
          <table
            role="presentation"
            width="520"
            cellspacing="0"
            cellpadding="0"
            border="0"
            style="
              max-width: 520px;
              width: 100%;
              background-color: #141414;
              border: 1px solid #2a2a2a;
              border-top: none;
              border-radius: 0 0 12px 12px;
            "
          >
            <tr>
              <td style="padding: 48px 40px 40px">
                <!-- Logo / Brand -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                  <tr>
                    <td align="center" style="padding-bottom: 32px">
                      <div
                        style="
                          font-size: 28px;
                          font-weight: 700;
                          color: #f5c842;
                          letter-spacing: 1px;
                        "
                      >
                        PENGUIN
                      </div>
                      <div
                        style="
                          font-size: 11px;
                          color: #666;
                          letter-spacing: 3px;
                          text-transform: uppercase;
                          margin-top: 4px;
                        "
                      >
                        CMS PLATFORM
                      </div>
                    </td>
                  </tr>
                </table>

                <!-- Heading -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                  <tr>
                    <td align="center" style="padding-bottom: 8px">
                      <h1 style="margin: 0; font-size: 24px; font-weight: 600; color: #ffffff">
                        Reset Your Password
                      </h1>
                    </td>
                  </tr>
                  <tr>
                    <td align="center" style="padding-bottom: 32px">
                      <p style="margin: 0; font-size: 15px; color: #999; line-height: 1.5">
                        We received a request to reset your password
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Divider -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                  <tr>
                    <td style="height: 1px; background-color: #2a2a2a"></td>
                  </tr>
                </table>

                <!-- Body text -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                  <tr>
                    <td style="padding: 32px 0">
                      <p
                        style="margin: 0 0 16px; font-size: 15px; color: #cccccc; line-height: 1.6"
                      >
                        Hi <strong style="color: #ffffff"><%= firstName %></strong>,
                      </p>
                      <p
                        style="margin: 0 0 16px; font-size: 15px; color: #cccccc; line-height: 1.6"
                      >
                        Someone requested a password reset for your Penguin account. Click the
                        button below to choose a new password.
                      </p>
                      <p style="margin: 0; font-size: 13px; color: #888; line-height: 1.5">
                        This link will expire in <strong style="color: #daa520">1 hour</strong>.
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- CTA Button -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                  <tr>
                    <td align="center" style="padding: 8px 0 32px">
                      <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                        <tr>
                          <td
                            align="center"
                            style="
                              border-radius: 8px;
                              background: linear-gradient(135deg, #b8860b, #daa520, #f5c842);
                            "
                          >
                            <a
                              href="<%= resetUrl %>"
                              target="_blank"
                              style="
                                display: inline-block;
                                padding: 14px 48px;
                                font-size: 15px;
                                font-weight: 600;
                                color: #0a0a0a;
                                text-decoration: none;
                                border-radius: 8px;
                                letter-spacing: 0.3px;
                              "
                              >Reset Password</a
                            >
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Divider -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                  <tr>
                    <td style="height: 1px; background-color: #2a2a2a"></td>
                  </tr>
                </table>

                <!-- Fallback link -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                  <tr>
                    <td style="padding: 24px 0 0">
                      <p style="margin: 0 0 12px; font-size: 13px; color: #666; line-height: 1.5">
                        If the button doesn't work, copy and paste this URL into your browser:
                      </p>
                      <p style="margin: 0; font-size: 12px; word-break: break-all">
                        <a href="<%= resetUrl %>" style="color: #daa520; text-decoration: none"
                          ><%= resetUrl %></a
                        >
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>

          <!-- Footer -->
          <table
            role="presentation"
            width="520"
            cellspacing="0"
            cellpadding="0"
            border="0"
            style="max-width: 520px; width: 100%"
          >
            <tr>
              <td align="center" style="padding: 24px 0 0">
                <p style="margin: 0 0 4px; font-size: 12px; color: #555">
                  If you didn't request a password reset, you can safely ignore this email. Your
                  password won't change.
                </p>
                <p style="margin: 0; font-size: 11px; color: #444">
                  &copy; <%= new Date().getFullYear() %> Penguin. All rights reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
