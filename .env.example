# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=7777
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/penguin_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_to_another_strong_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@penguin.dev

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4200
